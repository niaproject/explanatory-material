{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python .*$)",
      "Bash(cd .*$)",
      "WebFetch(domain:.*)",
      "WebFetch(domain:networkheresy.wordpress.com)",
      "WebFetch(domain:blogs.vmware.com)",
      "WebFetch(domain:arthurchiao.art)"
    ],
    "additionalDirectories": [
      "d:\\VSCode\\.*"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "defaultMode": "bypassPermissions"
}
